# ============================================
# Obsidian 笔记库 - 只跟踪笔记内容
# ============================================

# --- 媒体文件 (音频、视频、PDF) ---
# 图片 (*.jpg, *.png, *.gif 等) 是笔记内容的一部分，会被跟踪
*.mp4
*.webm
*.ogg
*.mp3
*.wav
*.flac
*.pdf

# --- 附件与文档 ---
*.doc
*.docx
*.xls
*.xlsx
*.ppt
*.pptx
*.zip
*.rar
*.7z
*.tar
*.gz

# --- Obsidian 配置目录 (整体不跟踪) ---
.obsidian/

# --- Obsidian 缓存与临时文件 ---
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/workspace
.obsidian/*.workspace
.obsidian/graph.json
.obsidian/markdown-cache
.obsidian/*cache*

# --- Obsidian 插件数据 (保留配置，忽略用户数据) ---
.obsidian/plugins/*/data.json
.obsidian/plugins/*/data.json.backup
.obsidian/plugins/*/.cache
.obsidian/plugins/*/cache

# --- 系统文件 ---
.DS_Store
*.swp
*.swo
*~
Thumbs.db
desktop.ini

# --- 编辑器与 IDE ---
.vscode/
.idea/
*.sublime-*

# --- Claude Code 项目配置 (个人配置) ---
.claude/settings.local.json
.claude/memory/

# --- 保留目录结构 ---
# 如果某个目录应该被保留但内容不跟踪，使用以下模式：
# media-lib/*
# media-track/*
# !media-lib/.gitkeep
